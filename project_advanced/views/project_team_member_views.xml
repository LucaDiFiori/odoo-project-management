<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="project_team_member_view_tree" model="ir.ui.view">
        <field name="name">project.team.member.view.list</field>
        <field name="model">project.team.member</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="project_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="role"/>
                <field name="email"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="project_team_member_view_form" model="ir.ui.view">
        <field name="name">project.team.member.view.form</field>
        <field name="model">project.team.member</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group name="member_details">
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="role"/>
                        </group>
                        <group name="project_details">
                            <field name="project_id"/>
                            <field name="email"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="project_team_member_view_search" model="ir.ui.view">
        <field name="name">project.team.member.view.search</field>
        <field name="model">project.team.member</field>
        <field name="arch" type="xml">
            <search string="Team Members">
                <field name="user_id"/>
                <field name="project_id"/>
                <separator/>
                <filter name="team_lead" string="Team Leads"
                        domain="[('role', '=', 'team_lead')]"/>
                <filter name="developer" string="Developers"
                        domain="[('role', '=', 'developer')]"/>
                <filter name="tester" string="Testers"
                        domain="[('role', '=', 'tester')]"/>
                <filter name="analyst" string="Analysts"
                        domain="[('role', '=', 'analyst')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_by_project" string="Project"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_by_role" string="Role"
                            context="{'group_by': 'role'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_project_team_member" model="ir.actions.act_window">
        <field name="name">Team Members</field>
        <field name="res_model">project.team.member</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="project_team_member_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No team members assigned yet. Add members to your projects.
            </p>
        </field>
    </record>

</odoo>