<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="project_project_view_form_inherit" model="ir.ui.view">
        <field name="name">project.project.view.form.inherit.advanced</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <!-- Add Milestones tab after Description -->
            <page name="description" position="after">
                <page name="milestones_tab" string="Milestones">
                    <field name="milestone_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="deadline"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'in_progress'"
                                   decoration-success="state == 'done'"
                                   decoration-warning="state == 'todo'"/>
                            <field name="progress" widget="progressbar"/>
                            <field name="task_count" string="Tasks" help="Total number of tasks and subtasks linked to this milestone"/>
                        </list>
                    </field>
                </page>
                <page name="team_tab" string="Team">
                    <field name="team_member_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="role"/>
                            <field name="email"/>
                        </list>
                    </field>
                </page>
            </page>
        </field>
    </record>

</odoo>